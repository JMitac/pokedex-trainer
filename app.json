{
  "expo": {
    "name": "pokedex-trainer",
    "slug": "pokedex-trainer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "pokedex-trainer",
    "experiments": {
      "typedRoutes": false
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite acceder a tu galería para seleccionar tu foto de entrenador.",
          "cameraPermission": "Permite usar la cámara para tomar tu foto de entrenador."
        }
      ],
      "expo-font"
    ]
  }
}
